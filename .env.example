# Eco-Echo AI Scholar Configuration
# Copy this file to .env and fill in your values

# Required: Your API key (OpenAI or compatible proxy)
VITE_AI_API_KEY=sk-your-key-here

# Optional: Custom API endpoint (default: https://api.openai.com/v1/chat/completions)
# Use a CORS-friendly proxy if calling from browser:
# VITE_AI_API_ENDPOINT=https://your-proxy.com/v1/chat/completions

# Optional: Model name (default: gpt-4o)
# VITE_AI_MODEL=gpt-4o
